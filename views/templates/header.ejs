<header>
  <div class="logo-container">
    <a href="/">
      <img
        src="/images/logo.png"
        class="logo-img"
        alt="incognito and two message bubbles icon"
      />
    </a>

    <div class="logo-text">
      <p class="incognito">incognito</p>
      <p class="accent">members only</p>
    </div>
  </div>

  <nav>
    <% if (currentUser) {%>
    <a href="/log-out">LOG OUT</a>
    <% } else { %>
    <a href="/log-in">LOG IN</a>
    <p class="accent">|</p>
    <a href="/sign-up">SIGN UP</a>
    <% } %>
  </nav>
</header>
